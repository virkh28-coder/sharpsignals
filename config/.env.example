# Copy to .env and fill in. NEVER commit .env to git.

# === AI ===
ANTHROPIC_API_KEY=sk-ant-...

# === Data APIs ===
THE_ODDS_API_KEY=
SPORTMONKS_API_KEY=
FOOTBALL_DATA_API_KEY=

# === Instagram (Meta Graph API) ===
# Long-lived Page access token with: instagram_basic, instagram_content_publish,
# pages_show_list, pages_read_engagement
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
IG_BUSINESS_ACCOUNT_ID=
FB_PAGE_ID=
# Meta requires a publicly fetchable URL to ingest the bet-slip image.
# Either host static at sharpsignals.org/media/ or use an R2/S3 bucket.
GRAPHIC_PUBLIC_BASE_URL=https://sharpsignals.org/media

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@sharpsignals

# === Google Sheets (public track record) ===
GOOGLE_SHEETS_CREDENTIALS_PATH=./config/google_service_account.json
GOOGLE_SHEET_ID=

# === Alerts ===
DISCORD_WEBHOOK_URL=

# === App ===
TIMEZONE=America/Toronto
LOG_LEVEL=INFO
DATA_DIR=./data
